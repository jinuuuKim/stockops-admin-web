# StockOps Admin Web Environment Variables
# Public-safe template only. Copy to .env.local locally.
# IMPORTANT: VITE_* values are bundled into browser JavaScript. Do not put real secrets here.

# API Base URL
VITE_API_BASE_URL=http://localhost:8080
# Production behind reverse proxy:
# VITE_API_BASE_URL=/api

# Build target
VITE_BUILD_TARGET=es2020

# Source map, false for production
VITE_BUILD_SOURCEMAP=false

# Live sensor values are served by the API server (Redis recent-reading cache)
# over authenticated REST endpoints. The browser no longer connects to MQTT.

# Admin AI chat, session-only storage key. Not a secret.
VITE_ADMIN_CHAT_SESSION_STORAGE_KEY=stockops.admin.chat.messages
VITE_ADMIN_CHAT_CONTEXT_MESSAGE_LIMIT=12
