# StockOps Web Environment Variables
# Copy to .env.local and fill in real values

# API Base URL (development)
VITE_API_BASE_URL=http://localhost:8080

# API Base URL (production)
# VITE_API_BASE_URL=/api

# Build target
VITE_BUILD_TARGET=es2020

# Source map (false for production)
VITE_BUILD_SOURCEMAP=false

# Live sensor MQTT over WebSocket (admin-web subscribes directly)
VITE_MQTT_WS_URL=ws://localhost:9001
VITE_MQTT_USERNAME=stockops_dev_reader
VITE_MQTT_PASSWORD=change-me-locally
VITE_MQTT_SENSOR_TOPIC_FILTER=sensimul/sites/+/sensors/+

# Admin AI chat (session-only, no DB/cookie)
VITE_ADMIN_CHAT_SESSION_STORAGE_KEY=stockops.admin.chat.messages
VITE_ADMIN_CHAT_CONTEXT_MESSAGE_LIMIT=12
